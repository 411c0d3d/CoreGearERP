## CoreGearERP .gitignore
## Covers: .NET 10, Angular, Rider, Visual Studio, Docker, environment files

# ─── .NET Build Results ───────────────────────────────────────────────────────
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
artifacts/

# ─── .NET Core ────────────────────────────────────────────────────────────────
project.lock.json
project.fragment.lock.json
*.user
*.suo
*.userosscache
*.sln.docstates

# ─── NuGet ────────────────────────────────────────────────────────────────────
*.nupkg
*.snupkg
.nuget/
packages/
!**/packages/build/
nuget.config

# ─── ASP.NET ──────────────────────────────────────────────────────────────────
ScaffoldingReadMe.txt
bundleconfig.json

# ─── MSBuild ──────────────────────────────────────────────────────────────────
*.binlog

# ─── Test Results ─────────────────────────────────────────────────────────────
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml
coverage*/
CodeCoverage/
*.coverage
*.coveragexml
trx/

# ─── Environment and Secrets ──────────────────────────────────────────────────
.env
.env.*
!.env.example
appsettings.Development.json
appsettings.Local.json
secrets.json
**/secrets.json

# ─── Angular ──────────────────────────────────────────────────────────────────
**/node_modules/
dist/
tmp/
out-tsc/
.angular/cache/
.sass-cache/
connect.lock
libpeerconnection.log
npm-debug.log*
yarn-error.log
testem.log
/typings
.DS_Store
Thumbs.db
package-lock.json
yarn.lock

# ─── JetBrains Rider ──────────────────────────────────────────────────────────
.idea/
*.sln.iml
.idea_modules/

# ─── Visual Studio ────────────────────────────────────────────────────────────
.vs/
*.rsuser
*.vsp
*.vspx
*.sap

# ─── Docker ───────────────────────────────────────────────────────────────────
.docker/
docker-compose.override.yml

# ─── Terraform / Infra (for later) ───────────────────────────────────────────
*.tfstate
*.tfstate.*
.terraform/
*.tfvars
!*.tfvars.example

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Misc ─────────────────────────────────────────────────────────────────────
~$*
*~
*.orig
*.bak
*.tmp