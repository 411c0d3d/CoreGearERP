### Step 19d -- Verify component stock consumed
GET {{HostAddress}}/inventory/stock-items/{{componentStockItemId}}/movements
Authorization: Bearer {{BearerToken}}

> {%
    client.test("Component GoodsIssue movement created", function() {
        client.assert(response.status === 200, "Expected 200");
        var issueMovement = response.body.find(function(m) { return m.movementType === "GoodsIssue"; });
        client.assert(issueMovement !== undefined, "Expected GoodsIssue movement");
        client.assert(issueMovement.quantity === 50, "Expected 50 KG issued");
    });
%}

####
# @no-log
####

### Step 19e -- Verify finished goods added
GET {{HostAddress}}/inventory/stock-items/{{finishedStockItemId}}/movements
Authorization: Bearer {{BearerToken}}

> {%
    client.test("Finished goods ProductionReceipt movement created", function() {
        client.assert(response.status === 200, "Expected 200");
        client.assert(response.body.length === 1, "Expected 1 movement");
        client.assert(response.body[0].movementType === "ProductionReceipt", "Expected ProductionReceipt");
        client.assert(response.body[0].quantity === 10, "Expected 10 PCS");
    });
%}

####
# @no-log
####

### Step 19f -- Verify final stock levels after production
GET {{HostAddress}}/inventory/stock-items
Authorization: Bearer {{BearerToken}}

> {%
    client.test("Stock levels correct after production", function() {
        client.assert(response.status === 200, "Expected 200");
        var component = response.body.find(function(s) { return s.productCode === "COMP-STEEL"; });
        var finished = response.body.find(function(s) { return s.productCode === "PROD-FINISHED"; });
        client.assert(component.quantityOnHand === 50, "Expected 50 KG component remaining");
        client.assert(component.quantityReserved === 0, "Expected 0 KG reserved after completion");
        client.assert(finished.quantityOnHand === 10, "Expected 10 PCS finished goods");
    });
%}

