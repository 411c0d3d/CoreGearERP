### Step 18 -- Verify production order is Confirmed
GET {{HostAddress}}/production/orders
Authorization: Bearer {{BearerToken}}

> {%
    client.test("Production order status is Confirmed", function() {
        client.assert(response.status === 200, "Expected 200");
        client.assert(response.body.length > 0, "Expected at least one production order");
        client.assert(response.body[0].status === "Confirmed", "Expected Confirmed");
    });
%}

####
# @no-log
####

### Step 19 -- Verify component stock is reserved
GET {{HostAddress}}/inventory/stock-items
Authorization: Bearer {{BearerToken}}

> {%
    client.test("Component stock has reservation", function() {
        client.assert(response.status === 200, "Expected 200");
        var component = response.body.find(function(s) { return s.productCode === "COMP-STEEL"; });
        client.assert(component !== undefined, "Expected component stock item");
        client.assert(component.quantityOnHand === 100, "Expected 100 KG on hand");
        client.assert(component.quantityReserved === 50, "Expected 50 KG reserved");
        client.assert(component.quantityAvailable === 50, "Expected 50 KG available");
    });
%}

####
# @no-log
####

