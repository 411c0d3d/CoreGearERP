### Step 24 -- Verify finished goods stock is reserved
GET {{HostAddress}}/inventory/stock-items
Authorization: Bearer {{BearerToken}}

> {%
    client.test("Finished goods stock has reservation", function() {
        client.assert(response.status === 200, "Expected 200");
        var finished = response.body.find(function(s) { return s.productCode === "PROD-FINISHED"; });
        client.assert(finished !== undefined, "Expected finished goods stock item");
        client.assert(finished.quantityOnHand === 10, "Expected 10 PCS on hand");
        client.assert(finished.quantityReserved === 5, "Expected 5 PCS reserved");
        client.assert(finished.quantityAvailable === 5, "Expected 5 PCS available");
    });
%}

