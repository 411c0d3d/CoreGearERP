### Step 2 -- Create finished product
POST {{HostAddress}}/inventory/products
Authorization: Bearer {{BearerToken}}
Content-Type: application/json

{
  "code": "PROD-FINISHED",
  "name": "Finished Steel Assembly",
  "unitCode": "PCS",
  "description": "Finished product produced from raw steel"
}

> {%
    client.test("Finished product created", function() {
        client.assert(response.status === 201, "Expected 201");
        client.global.set("finishedProductId", response.body.id);
    });
%}

####
# @no-log
